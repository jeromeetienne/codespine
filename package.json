{
	"name": "ts-knowledge-graph",
	"version": "0.1.1",
	"description": "Parse TypeScript source into a knowledge graph for autonomous code optimization",
	"type": "module",
	"bin": {
		"ts-knowledge-graph": "dist/cli.js"
	},
	"files": [
		"dist",
		"contribs/web_visualisation/web",
		"skills/ts-knowledge-graph/SKILL.md",
		"README.md",
		"LICENSE",
		".env-sample"
	],
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"extract": "tsx src/cli.ts extract",
		"web": "tsx src/cli.ts web",
		"dev": "tsx src/cli.ts",
		"build": "tsc -p tsconfig.build.json",
		"publish:all": "npm run build && npm version patch && npm publish",
		"typecheck": "tsc --noEmit",
		"test": "node --import tsx --test \"test/**/*.test.ts\""
	},
	"dependencies": {
		"chalk": "^5.3.0",
		"commander": "^12.1.0",
		"kuzu": "^0.11.3",
		"openai": "^6.42.0",
		"ts-morph": "^23.0.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/node": "^20.14.0",
		"tsx": "^4.16.0",
		"typescript": "^5.5.0"
	}
}
