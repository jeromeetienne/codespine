{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"strict": true,
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"types": []
	},
	"include": ["js/app.js", "types/**/*.d.ts"]
}
